{
 "functions": {
    "python-api/download.py": {
      "runtime": "python3.12",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/download",
      "destination": "/python-api/download.py"
    }
  ],
  "builds": [
    {
      "src": "api/download.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/download",
      "dest": "/api/download.py"
    }
  ]
}
